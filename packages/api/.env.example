# Copiez ce fichier en ".env" et remplissez les valeurs (jamais commité, voir .gitignore).

# Chaîne de connexion Postgres. En local : URL fournie par votre base Postgres de dev
# (Render, Neon, etc.). En production : injectée automatiquement par Render (voir render.yaml).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret de signature des cookies de session — une chaîne longue et aléatoire.
# En production sur Render, laissez render.yaml la générer automatiquement (generateValue: true).
SESSION_SECRET="change-me-to-a-long-random-string"

# Port d'écoute local de l'API (non utilisé en production, Render impose PORT).
API_PORT=4000

# Origine autorisée pour les requêtes cross-origin (CORS) + cookies : l'URL du frontend.
WEB_ORIGIN="http://localhost:5173"

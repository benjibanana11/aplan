generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres (déploiement partagé, 2026-07-19) — remplace le SQLite local utilisé pendant le développement.
  // Les valeurs autorisées pour les champs "String" ci-dessous restent définies dans packages/shared/src/enums.ts
  // (des enums natifs Postgres seraient possibles mais non nécessaires : aucun gain fonctionnel ici).
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  teamCode  String   @unique
  createdAt DateTime @default(now())

  users           User[]
  tasks           Task[]
  schedulePresets SchedulePreset[]
}

// --- Multi-entreprises / multi-équipes (en cours de migration, voir le plan associé) ---
// Company/Team/TeamMembership remplaceront Organization + User.organizationId/role/active à
// terme. Pendant la migration, les deux modèles coexistent : Organization reste la source de
// vérité tant que le backfill (script one-off) et la bascule du code applicatif n'ont pas eu lieu.
model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  teams Team[]
}

model Team {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  teamCode  String   @unique
  createdAt DateTime @default(now())

  memberships     TeamMembership[]
  tasks           Task[]
  schedulePresets SchedulePreset[]
  workSchedules   WorkSchedule[]
  planningBlocks  PlanningBlock[]
  absences        Absence[]
  employeeTaskSkills EmployeeTaskSkill[]

  @@index([companyId])
}

model TeamMembership {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role   String  @default("EMPLOYEE")
  active Boolean @default(true)

  @@unique([userId, teamId])
  @@index([teamId])
}

model User {
  id             String   @id @default(cuid())
  // Nullable : les nouveaux comptes créés après la bascule vers Company/Team (voir TeamMembership
  // ci-dessus) n'ont plus d'Organization directe. Champ conservé jusqu'au nettoyage différé du
  // schéma (Étape D du plan) pour ne pas perdre l'historique des comptes créés avant la bascule.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  email          String   @unique
  passwordHash   String
  role           String   @default("EMPLOYEE")
  active         Boolean  @default(true)
  hireDate       DateTime
  createdAt      DateTime @default(now())

  memberships       TeamMembership[]
  skills            EmployeeTaskSkill[] @relation("EmployeeSkills")
  validatedSkills   EmployeeTaskSkill[] @relation("SkillValidator")
  workSchedules     WorkSchedule[]
  planningBlocks    PlanningBlock[]
  absences          Absence[]           @relation("AbsentUser")
  suggestedFor      Absence[]           @relation("SuggestedReplacement")
  validatedAbsences Absence[]           @relation("AbsenceValidator")

  @@index([organizationId])
}

model Task {
  id                  String      @id @default(cuid())
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  teamId              String?
  team                Team?       @relation(fields: [teamId], references: [id])
  name                String
  description         String
  category            String
  allowedSlot         String      @default("ALL_DAY")
  customStartTime     String?
  customEndTime       String?
  maxContinuousMinutes Int
  minStaff            Int
  targetStaff         Int
  maxStaff            Int
  maxTraineeSlots     Int         @default(0)
  requiresTraining    Boolean     @default(true)
  priorityRank        Int
  createdAt           DateTime    @default(now())

  skills          EmployeeTaskSkill[]
  planningBlocks  PlanningBlock[]

  @@unique([organizationId, priorityRank])
  @@unique([teamId, priorityRank])
  @@index([organizationId])
  @@index([teamId])
}

model EmployeeTaskSkill {
  employeeId      String
  employee        User        @relation("EmployeeSkills", fields: [employeeId], references: [id], onDelete: Cascade)
  taskId          String
  task            Task        @relation(fields: [taskId], references: [id])
  teamId          String?
  team            Team?       @relation(fields: [teamId], references: [id])
  status          String      @default("EN_FORMATION")
  hoursCompleted  Float       @default(0)
  hoursRequired   Float
  validatedAt     DateTime?
  validatedByUserId String?
  validatedBy     User?       @relation("SkillValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)

  @@id([employeeId, taskId])
  @@index([teamId])
}

model WorkSchedule {
  id         String   @id @default(cuid())
  employeeId String
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  teamId     String?
  team       Team?    @relation(fields: [teamId], references: [id])
  date       DateTime
  startTime  String
  endTime    String

  @@unique([employeeId, date])
  @@index([date])
  @@index([teamId])
}

model PlanningBlock {
  id            String   @id @default(cuid())
  employeeId    String
  employee      User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id])
  teamId        String?
  team          Team?    @relation(fields: [teamId], references: [id])
  date          DateTime
  startTime     String
  endTime       String
  source        String   @default("GENERATED")
  justification String
  isTraining    Boolean  @default(false)
  trainerName   String?
  needsRevalidation Boolean @default(false)

  @@index([date])
  @@index([employeeId, date])
  @@index([taskId, date])
  @@index([teamId])
}

// Table de sessions gérée par connect-pg-simple (packages/api/src/index.ts), pas par l'app elle-même
// — déclarée ici uniquement pour que `prisma db push` ne la prenne pas pour une table orpheline et
// ne tente pas de la supprimer (ce qui déconnecterait tout le monde).
model Session {
  sid    String   @id @db.VarChar
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], name: "IDX_session_expire")
  @@map("session")
}

// Créneaux horaires génériques ("6h-14h", "9h-17h"...) que l'admin définit une fois et réutilise
// en un clic sur la page Horaire, pour accélérer la saisie répétitive des horaires mensuels.
model SchedulePreset {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  teamId         String?
  team           Team?        @relation(fields: [teamId], references: [id])
  startTime      String
  endTime        String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, startTime, endTime])
  @@unique([teamId, startTime, endTime])
  @@index([organizationId])
  @@index([teamId])
}

model Absence {
  id                       String   @id @default(cuid())
  employeeId               String
  employee                 User     @relation("AbsentUser", fields: [employeeId], references: [id], onDelete: Cascade)
  teamId                   String?
  team                     Team?    @relation(fields: [teamId], references: [id])
  date                     DateTime
  reason                   String?
  status                   String   @default("PENDING")
  suggestedReplacementUserId String?
  suggestedReplacement     User?    @relation("SuggestedReplacement", fields: [suggestedReplacementUserId], references: [id], onDelete: SetNull)
  validatedByUserId        String?
  validatedBy              User?    @relation("AbsenceValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  createdAt                DateTime @default(now())

  @@index([employeeId, date])
  @@index([teamId])
}
